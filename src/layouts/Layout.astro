---
import { site, contact, social } from '../config/site';

// Self-hosted fonts via Fontsource. Latin subset only (site is in English
// with occasional Spanish accents). Bundled and fingerprinted by Vite.
// Only weights actually used by the design system are imported — see
// the audit table in CLAUDE.md before adding more.
import '@fontsource/bebas-neue/latin-400.css';        // h1, display
import '@fontsource/barlow/latin-400.css';            // body
import '@fontsource/barlow/latin-500.css';            // CTA labels
import '@fontsource/barlow/latin-600.css';            // FAQ question, WorkCard strong
import '@fontsource/barlow/latin-700.css';            // h4, skip-link, About strong
import '@fontsource/barlow-condensed/latin-800.css';  // h3, btn-rg
import '@fontsource/cormorant-garamond/latin-300-italic.css'; // h2, para-lg, intro

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description,
} = Astro.props;

const url = Astro.url;
// Absolute URL so social crawlers resolve the asset regardless of where
// the page is served from. Asset still has to exist in /public/images/.
const ogImage = new URL(site.ogImage, url).toString();
const avatarUrl = new URL(site.avatar, url).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${site.url}/#person`,
  name: site.name,
  givenName: site.givenName,
  familyName: site.familyName,
  jobTitle: site.role,
  description: site.description,
  url: site.url,
  image: avatarUrl,
  email: contact.email,
  nationality: site.nationality,
  knowsAbout: site.knowsAbout,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.location.city,
    addressRegion: site.location.region,
    addressCountry: site.location.country,
  },
  sameAs: [social.linkedin.url, social.github.url],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${site.url}/#website`,
  url: site.url,
  name: site.name,
  description: site.description,
  inLanguage: site.lang,
  publisher: { '@id': `${site.url}/#person` },
};
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="theme-color" content={site.themeColor} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="generator" content={Astro.generator} />

    <!-- OG / Social -->
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(site.ogImageWidth)} />
    <meta property="og:image:height" content={String(site.ogImageHeight)} />
    <meta property="og:image:alt" content={site.ogImageAlt} />
    <link rel="canonical" href={url} />

    <!-- Fonts are self-hosted via @fontsource imports in the frontmatter.
         No third-party font CDN is hit at runtime. -->

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    <!-- IndieWeb / Mastodon-style identity confirmation. Search engines and
         IndieAuth use rel="me" links to verify that profiles belong to the
         same person as the canonical site. -->
    <link rel="me" href={social.linkedin.url} />
    <link rel="me" href={social.github.url} />
    <link rel="me" href={contact.mailto} />

    <title>{title}</title>

    <!-- Structured data: Person + WebSite schemas, linked by @id so search
         engines treat them as a single knowledge-graph entity. -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Theme init: runs before first paint to avoid flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-theme', stored || (prefersDark ? 'dark' : 'light'));
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div id="page-scrim" aria-hidden="true"></div>
    <slot />
    <canvas id="grain-canvas" aria-hidden="true"></canvas>
    <div id="cursor" class="cursor" aria-hidden="true"></div>
  </body>
</html>

<style is:global>
  @import '../styles/theme.css';
  @import '../styles/tokens.css';
  @import '../styles/typography.css';
  @import '../styles/global.css';

  /* Scroll-driven dark overlay — sits between hero (z-index 0) and
     overlay-stack content (z-index 1) at root level */
  #page-scrim {
    position: fixed;
    inset: 0;
    z-index: 1;
    background: #000;
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }

  /* Grain noise overlay */
  #grain-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 500;
    pointer-events: none;
    opacity: 0.04;
  }

  /* ================================================
     Custom cursor — white circle, invert via difference
  ================================================ */
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #fff;
    pointer-events: none;
    mix-blend-mode: difference;
    z-index: 9999;
    transform: translate(var(--cx, -100px), var(--cy, -100px)) translate(-50%, -50%);
    transition: width 280ms cubic-bezier(0.2, 0.8, 0.2, 1),
                height 280ms cubic-bezier(0.2, 0.8, 0.2, 1),
                opacity 200ms;
    opacity: 0;
    will-change: transform, width, height;
  }

  .cursor.is-ready { opacity: 1; }

  .cursor.is-active {
    width: 72px;
    height: 72px;
  }

  @media (hover: hover) and (pointer: fine) {
    html, body { cursor: none; }
    a, button, [role="button"], label { cursor: none; }
  }

  /* Restore the system cursor when motion is reduced or input is coarse —
     low-vision users, screen-magnifier users, and touch devices all rely
     on it. The custom cursor itself is also hidden below. */
  @media (hover: none), (pointer: coarse), (prefers-reduced-motion: reduce) {
    html, body { cursor: auto; }
    a, button, [role="button"], label { cursor: pointer; }
    .cursor { display: none; }
  }

  /* ================================================
     Scroll reveal
     ─ Modern path: CSS scroll-driven animations
       (animation-timeline: view()) — scrub-tied to viewport entry
     ─ Fallback: IntersectionObserver toggles .is-visible
  ================================================ */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity  700ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 700ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: opacity, transform;
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger delays (1–6) — only the IO fallback uses these */
  [data-reveal][data-reveal-delay="1"] { transition-delay: 80ms; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 160ms; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 240ms; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 320ms; }
  [data-reveal][data-reveal-delay="5"] { transition-delay: 400ms; }
  [data-reveal][data-reveal-delay="6"] { transition-delay: 480ms; }

  /* Native scroll-driven animations — scrubbed by viewport position.
     Gated on body.reveals-ready so the loader can hold them off. */
  @supports (animation-timeline: view()) {
    body.reveals-ready [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
      animation: reveal-rise linear both;
      animation-timeline: view();
      animation-range: entry 0% cover 15%;
    }

    @keyframes reveal-rise {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
      animation: none;
    }
  }

  /* ================================================
     Mask reveal — words slide up from behind a clip
  ================================================ */
  .mask-reveal__word {
    display: inline-block;
    overflow: hidden;
    vertical-align: top;
    /* extra room so descenders (g, p, y) aren't clipped */
    padding-block: 0.15em;
    margin-block: -0.15em;
  }

  .mask-reveal__inner {
    display: inline-block;
    transform: translateY(110%);
    transition: transform 950ms cubic-bezier(0.215, 0.61, 0.355, 1);
    transition-delay: calc(var(--i, 0) * 70ms);
    will-change: transform;
  }

  [data-mask-reveal].is-mask-revealed .mask-reveal__inner {
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .mask-reveal__inner {
      transform: none;
      transition: none;
    }
  }

  /* ================================================
     Lenis smooth scroll
  ================================================ */
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: hidden; }
  .lenis.lenis-smooth iframe { pointer-events: none; }
</style>

<script>
  // Site-wide wiring. Each concern lives in its own module under
  // src/scripts/ so this file stays an orchestrator, not a god-file.
  import { initSmoothScroll } from '../scripts/SmoothScroll';
  import { initPageScrim } from '../scripts/PageScrim';
  import { initReveal, setupMaskReveals } from '../scripts/Reveal';
  import { initGrain } from '../scripts/GrainCanvas';
  import { initCustomCursor } from '../scripts/CustomCursor';

  initSmoothScroll();
  initPageScrim();
  initGrain();
  initCustomCursor();

  // Lazy-load the heavier effects so the critical-path bundle stays small.
  import('../scripts/TextDistortion').then(({ initTextDistortions }) => {
    initTextDistortions();
  });
  import('../scripts/ScrambleHover').then(({ initScrambleHover }) => {
    initScrambleHover();
  });

  // Split words immediately so they're hidden before loader:done fires.
  setupMaskReveals();

  // Guard against double-init: if the loader fires AFTER the 4s fallback
  // already ran, both paths would call initReveal() and leave behind a
  // duplicate set of IntersectionObservers.
  let revealed = false;
  const safeInitReveal = () => {
    if (revealed) return;
    revealed = true;
    initReveal();
  };

  document.addEventListener('loader:done', safeInitReveal);

  const fallback = setTimeout(() => {
    document.body.classList.add('hero-ready');
    safeInitReveal();
  }, 4000);
  document.addEventListener('loader:done', () => clearTimeout(fallback));
</script>
