---
import { fillTokens } from '../config/site';
import nav from '../content/nav.json';
---

<nav id="navbar" class="navbar">
  <div class="navbar__inner container">
    <div class="line navbar__top-line">
      <span class="navbar__progress" id="navbar-progress" aria-hidden="true"></span>
    </div>

    <div class="navbar__layout">

      <div class="navbar__col is-left">
        <a href="#" data-scroll-top class="navbar__logo" aria-label={nav.logoAriaLabel}>
          <svg class="navbar__logo-svg" viewBox="0 0 359.9 344.7" width="29" height="28" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <style>.st0{fill:var(--c-logo)}.st1{opacity:.15}.st2{fill:url(#sg1)}.st3{fill:url(#sg2)}.st4{fill:url(#sg3)}</style>
            <g>
              <g>
                <polygon class="st0" points="320.9,0 359.9,67.5 279.9,206.2 202.7,206.2"/>
                <polygon class="st0" points="320.8,275.4 281.3,341.9 202.7,206.2 241.6,138.6"/>
                <polygon class="st0" points="359.9,67.5 320.9,0 84.5,0 45.5,67.5"/>
                <polygon class="st0" points="39,344.7 0,277.2 80,138.6 157.2,138.6"/>
                <polygon class="st0" points="0,277.2 39,344.7 198.9,344.7 161.3,277.2"/>
              </g>
              <g class="st1">
                <linearGradient id="sg1" gradientUnits="userSpaceOnUse" x1="305.6" y1="115.1" x2="309.5" y2="70.8">
                  <stop offset="0" style="stop-color:#fff;stop-opacity:0"/>
                  <stop offset="1" style="stop-color:#000"/>
                </linearGradient>
                <polygon class="st2" points="333.1,114 255.5,114 282.2,67.5 359.9,67.5"/>
                <linearGradient id="sg2" gradientUnits="userSpaceOnUse" x1="243.8" y1="493.2" x2="247.7" y2="448.9" gradientTransform="matrix(-1 0 0 -1 298.8 722.8)">
                  <stop offset="0" style="stop-color:#fff;stop-opacity:0"/>
                  <stop offset="1" style="stop-color:#000"/>
                </linearGradient>
                <polygon class="st3" points="27.5,230.8 105,230.8 78.4,277.2 0.7,277.2"/>
                <linearGradient id="sg3" gradientUnits="userSpaceOnUse" x1="5.9" y1="448.2" x2="9.9" y2="403.6" gradientTransform="matrix(.5076 .8616 .8616 -.5076 -95.1 356.9)">
                  <stop offset="0" style="stop-color:#fff;stop-opacity:0"/>
                  <stop offset="1" style="stop-color:#000"/>
                </linearGradient>
                <polygon class="st4" points="307.8,157.7 268,92.2 241.6,138.6 280.3,205.4"/>
              </g>
            </g>
          </svg>
        </a>
      </div>

      <div class="navbar__col is-center">
        <nav class="navbar__links h4" aria-label={nav.linksAriaLabel}>
          {nav.links.map((link) => (
            <a
              href={fillTokens(link.href)}
              {...(link.scrollTop ? { 'data-scroll-top': true } : {})}
            ><span data-scramble>{link.label}</span></a>
          ))}
        </nav>
      </div>

      <div class="navbar__col is-right">
        <button
          type="button"
          class="theme-toggle"
          id="theme-toggle"
          aria-label={nav.themeToggle.labelToDark}
          aria-pressed="false"
          data-label-to-dark={nav.themeToggle.labelToDark}
          data-label-to-light={nav.themeToggle.labelToLight}
        >
          <span class="theme-toggle__swatch" aria-hidden="true"></span>
        </button>
      </div>

    </div>
  </div>
</nav>


<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding-top: var(--sp-12);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    /* position: fixed escapes body's overflow-x: clip; clip here so a
       wide child can't push a horizontal scrollbar. */
    overflow-x: clip;
  }

  .navbar__inner {
    display: flex;
    flex-direction: column;
  }

  .navbar__top-line {
    margin-bottom: var(--sp-12);
    position: relative;
    overflow: hidden;
  }

  .navbar__progress {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    background-color: var(--c-text);
    transform-origin: left center;
    transform: scaleX(var(--progress, 0));
    transition: transform 80ms linear;
    will-change: transform;
  }

  .navbar__layout {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    width: 100%;
    padding-bottom: 12px;
  }

  .navbar__col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-12);
    /* min-width: 0 lets grid items shrink below intrinsic size — otherwise
       a long link could push the navbar past viewport width. */
    min-width: 0;
  }

  .navbar__col.is-center {
    align-items: center;
    justify-content: flex-start;
  }

  .navbar__col.is-right {
    flex-direction: row;
    gap: var(--sp-12);
    align-items: center;
    justify-self: end;
  }


  .navbar__logo {
    display: inline-flex;
    /* align-self: flex-start so the focus ring hugs the SVG instead of
       stretching to the column width. */
    align-self: flex-start;
    width: fit-content;
    transition: opacity 200ms;
  }

  .navbar__logo:hover { opacity: 0.6; }

  /* 2px hugs the icon — global 4px ring reads as too much air around a 20px glyph. */
  .navbar__logo:focus-visible {
    outline: 2px solid var(--c-text);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .navbar__logo-svg {
    height: 20px;
    width: auto;
  }

.navbar__links {
    display: flex;
    gap: var(--sp-24);
  }

  .navbar__links a {
    color: var(--c-text);
    transition: opacity 200ms;
    /* WCAG 2.5.8 — ≥24px hit target without changing visual size. */
    padding-block: 0.6rem;
    display: inline-block;
  }

  .navbar__links a:hover { opacity: 0.5; }

  .navbar__logo {
    /* Hit area expanded via ::before so the focus ring still hugs the SVG. */
    position: relative;
  }

  .navbar__logo::before {
    content: '';
    position: absolute;
    inset: -0.5rem;
  }

  .theme-toggle {
    /* WCAG 2.5.5 — 44×44 hit target with 13px visible swatch centred. */
    width: 44px;
    height: 44px;
    margin: -0.7rem;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: opacity 200ms;
  }

  .theme-toggle:hover { opacity: 0.5; }

  .theme-toggle__swatch {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid var(--c-text);
    background: linear-gradient(to right, var(--c-text) 50%, var(--c-bg) 50%);
    display: block;
    transition: border-color 350ms var(--ease);
  }

  @media (max-width: 768px) {
    .navbar__layout {
      /* minmax(0, 1fr): default 1fr has min-width: auto and lets the centre
         track expand past the viewport when the 4 links + gaps don't fit. */
      grid-template-columns: auto minmax(0, 1fr) auto;
      column-gap: var(--sp-12);
    }

    .navbar__logo-svg {
      height: 1.75rem;
    }

    .navbar__links {
      justify-content: center;
      gap: clamp(0.3rem, 1.5vw, 0.75rem);
      /* Wrap to a second row at the smallest viewports rather than overflow. */
      flex-wrap: wrap;
      row-gap: 4px;
    }

  }

</style>

<script>
  const toggle = document.getElementById('theme-toggle')!;
  const root = document.documentElement;

  function getTheme(): string {
    return root.getAttribute('data-theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  }

  function syncToggleA11y() {
    const isDark = getTheme() === 'dark';
    toggle.setAttribute('aria-pressed', String(isDark));
    const labelToDark = toggle.dataset.labelToDark || 'Switch to dark theme';
    const labelToLight = toggle.dataset.labelToLight || 'Switch to light theme';
    toggle.setAttribute('aria-label', isDark ? labelToLight : labelToDark);
  }
  syncToggleA11y();

  toggle.addEventListener('click', () => {
    const next = getTheme() === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    syncToggleA11y();
  });

  const progress = document.getElementById('navbar-progress');
  if (progress) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const update = () => {
      const doc = document.documentElement;
      const scrollable = Math.max(0, doc.scrollHeight - window.innerHeight);
      const ratio = scrollable > 0
        ? Math.min(1, Math.max(0, window.scrollY / scrollable))
        : 0;
      progress.style.setProperty('--progress', String(ratio));
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    if (reduced) {
      progress.style.transition = 'none';
    }
  }
</script>
