---
import WorkCard from './WorkCard.astro';
import SectionMeta from './SectionMeta.astro';
import { fillTokens } from '../config/site';
import works from '../content/works.json';

const projects = works.projects;
const projectCount = String(projects.length).padStart(2, '0');
const metaRightLabel = works.metaRightLabelTemplate.replace('{count}', projectCount);
---

<section class="works" id="works" aria-label={works.ariaLabel}>
  <div class="works__wrapper container">

    <SectionMeta index={works.metaIndex} rightLabel={metaRightLabel} rightIcon="asterisk" />
    <div class="u-spacer-48"></div>

    <!-- Heading: SELECTED (display, distorted) + WORKS (italic serif) edge-to-edge -->
    <div class="works__heading-group" data-reveal>
      <div class="works__selected-wrap" data-text-distortion>
        <span class="works__selected h1" data-text-distortion-text>{works.headingSelected}</span>
        <canvas aria-hidden="true"></canvas>
      </div>
      <h2 id="works-heading" class="works__title h2" data-mask-reveal>{works.headingTitle}</h2>
    </div>

    <!-- 2-column project grid -->
    <div class="works__grid">
      {projects.map((p, i) => (
        <div data-reveal data-reveal-delay={String(i % 2 + 1)}>
        <WorkCard
          title={p.title}
          year={p.year}
          category={p.category}
          href={p.href}
          role={p.role}
          comingSoon={p.comingSoon}
          cardIndex={i + 1}
          description={p.description}
          techStack={p.techStack}
        />
        </div>
      ))}
    </div>

    <!-- Section close: hairline + GitHub link bottom-right. -->
    <div class="works__cta">
      <div class="u-spacer-36"></div>
      <div class="works__cta-inner" data-reveal>
        <div class="line line--draw" data-line-draw></div>
        <a
          href={fillTokens(works.seeMoreHref)}
          target="_blank"
          rel="noopener noreferrer"
          class="overline works__see-more"
        >
          {works.seeMorePrefix}<strong data-scramble>{fillTokens(works.seeMoreLabel)}</strong><span class="sr-only">{works.newTabSrText}</span>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .works {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }

  .works__wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: safe center;
    padding-block: var(--sp-144);
  }

  /* Heading group: SELECTED (left, italic serif) + WORKS (right, display).
     Same font-size on both, fitted to container width by JS for exact 100% fill. */
  .works__heading-group {
    width: 100%;
    padding-bottom: var(--sp-48);
    display: flex;
    justify-content: space-between;
    /* flex-end so the bottom of each word's line-box lines up — baseline
       alignment with mismatched line-heights left the italic appearing
       to float relative to the display caps on the left. */
    align-items: flex-end;
    gap: clamp(1rem, 2vw, 3rem);
    border-bottom: 1px solid var(--c-line);
    margin-bottom: var(--sp-36);
  }

  /* Same font-size clamp on both as fallback (mobile + pre-JS).
     The fit script overrides with an exact-fit inline font-size on desktop. */
  .works__selected,
  .works__title {
    flex-shrink: 0;
    font-size: clamp(2.5rem, 14vw, 22rem);
    /* Matched line-height so flex-end pins the same descender line on
       both — different line-heights produced different box bottoms. */
    line-height: 0.85;
  }

  /* 2-column grid */
  .works__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-12);
  }

  /* Section close: full-width hairline + right-aligned overline link
     under it — same rhythm as the FAQ closing strip. */
  .works__cta-inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .works__cta-inner .line {
    width: 100%;
    will-change: transform;
  }

  .works__see-more {
    align-self: flex-end;
    color: var(--c-text-muted);
    /* margin instead of padding so the focus-visible outline hugs the
       text instead of expanding into the gap above the link. */
    margin-top: var(--sp-24);
    transition: color 200ms;
  }

  .works__see-more:hover {
    color: var(--c-text);
  }

  @media (max-width: 768px) {
    .works__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Fit "SELECTED" + "WORKS" to the heading-group width. On mobile the
  // layout stacks; CSS clamp handles sizing there and JS clears overrides.
  function fitWorksHeading() {
    const heading = document.querySelector('.works__heading-group');
    if (!(heading instanceof HTMLElement)) return;
    const selected = heading.querySelector<HTMLElement>('.works__selected');
    const titleEl = heading.querySelector<HTMLElement>('.works__title');
    if (!selected || !titleEl) return;

    const baseFs = 100;
    selected.style.fontSize = `${baseFs}px`;
    titleEl.style.fontSize = `${baseFs}px`;

    const cs = window.getComputedStyle(heading);
    const gap = parseFloat(cs.columnGap) || 0;
    const containerW = heading.getBoundingClientRect().width;
    const selectedW = selected.getBoundingClientRect().width;
    const titleW = titleEl.getBoundingClientRect().width;

    // Optical compensation: Cormorant italic vs Bebas Neue at the same
    // point size — set to 1 means same display size. Tweak if italic
    // ever needs to feel smaller than the display caps on the left.
    const TITLE_VISUAL_SCALE = 1;
    const denom = selectedW + TITLE_VISUAL_SCALE * titleW;
    if (denom <= 0 || containerW <= 0) return;

    const newFs = (baseFs * (containerW - gap)) / denom;
    selected.style.fontSize = `${newFs}px`;
    titleEl.style.fontSize = `${newFs * TITLE_VISUAL_SCALE}px`;
  }

  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(fitWorksHeading);
  } else {
    fitWorksHeading();
  }
  window.addEventListener('resize', fitWorksHeading, { passive: true });
</script>
