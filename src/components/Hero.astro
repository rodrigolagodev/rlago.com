---
import { social } from '../config/site';
import hero from '../content/hero.json';
---

<section class="hero" aria-label={hero.ariaLabel}>

  <!-- Pixelated background canvas — same effect as Footer -->
  <div class="hero__bg" aria-hidden="true">
    <canvas id="hero-bg-canvas" width="9" height="9"></canvas>
  </div>

  <div class="hero__inner container">

    <!-- Center: massive role + italic description -->
    <div class="hero__center">
      <div
        class="hero__role hero-anim"
        style="--delay:160ms"
        data-text-distortion
        data-text-distortion-skip
      >
        <h1 class="hero__role-text h1" data-text-distortion-text>{hero.titleLine1}<br>{hero.titleLine2}</h1>
        <canvas id="hero-role-canvas" aria-hidden="true"></canvas>
      </div>
      <p class="hero__desc hero-anim" style="--delay:240ms">
        {hero.description}
      </p>
    </div>

    <!-- Bottom row: email click-to-copy + socials -->
    <div class="hero__bottom hero-anim" style="--delay:320ms">
      <button
        type="button"
        class="hero__scroll"
        id="hero-scroll"
        aria-label={hero.scrollAriaLabel}
      >
        <span class="overline hero__scroll-text">
          <span data-scramble>{hero.scrollLabel}</span>
          <span class="hero__scroll-arrow" aria-hidden="true">&darr;</span>
        </span>
      </button>

      <nav class="hero__socials" aria-label={hero.socialsAriaLabel}>
        <a
          class="overline"
          href={social.linkedin.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span data-scramble>{social.linkedin.label}</span><span class="sr-only">{hero.newTabSrText}</span>
        </a>
        <span class="overline hero__socials-sep" aria-hidden="true">·</span>
        <a
          class="overline"
          href={social.github.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span data-scramble>{social.github.label}</span><span class="sr-only">{hero.newTabSrText}</span>
        </a>
      </nav>
    </div>

  </div>
</section>

<style>
  /* ── Hero entry animations ───────────────────────────── */
  .hero-anim {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity  700ms cubic-bezier(0.4, 0, 0.2, 1) var(--delay, 0ms),
      transform 700ms cubic-bezier(0.4, 0, 0.2, 1) var(--delay, 0ms);
  }

  :global(body.hero-ready) .hero-anim {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim { opacity: 1; transform: none; transition: none; }
  }

  /* ── Layout ──────────────────────────────────────────── */
  .hero {
    height: 100svh;
    display: flex;
    flex-direction: column;
    overflow-x: clip;
    position: sticky;
    top: 0;
    z-index: 0;
  }

  /* Pixelated background canvas, same approach as the Footer.
     - .hero__bg fills the section, paints at z-index 0
     - the canvas is stretched up with image-rendering: pixelated so
       every internal pixel becomes a visible block
     - opacity 0.2 keeps the .hero__bg base colour (var(--c-bg)) as the
       dominant tone, so the hero feels light, with subtle pixel hints. */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background-color: var(--c-bg);
  }

  .hero__bg canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    filter: grayscale(1) contrast(2.15);
    opacity: 0.1;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: clamp(5rem, 7vh, 7rem);
    /* Bottom padding intentionally matches the lateral gutter
       (var(--gutter) → 8–12 px). This pulls the bottom row close
       to the viewport edge, giving the hero a tight, minimal frame
       that mirrors the gutter rhythm on the sides. */
    padding-bottom: var(--gutter);
    gap: var(--sp-36);
  }

  /* ── Bottom row ──────────────────────────────────────── */
  .hero__bottom {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sp-24);
    width: 100%;
  }

  /* ── Center: massive role + description ──────────────── */
  .hero__center {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: safe center;
    text-align: center;
  }

  /* The role wrapper takes the .container content width (= body width
     minus the container's gutter padding on each side). That way the
     role text aligns with every other section's content (bottom row,
     marquee, works, etc.) and leaves the same gutter padding on the
     edges instead of running flush against the viewport. */
  .hero__role {
    display: block;
    width: 100%;
  }

  .hero__role-text {
    /* inline-block so the wrapper height collapses to the text's height
       (instead of the parent line-box) and the canvas overlay sits flush. */
    display: inline-block;
    /* h1 defaults to bold (700); Bebas Neue only ships 400, so the browser
       fakes synthetic bold and the DOM width drifts from the canvas width.
       Force 400 so both measurements agree. */
    font-weight: 400;
    /* Pre-JS fallback. fitHeroRole() overrides with an exact-fit size. */
    font-size: clamp(3rem, 14vw, 26rem);
    line-height: 0.85;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0;
    white-space: nowrap;
  }

  .hero__desc {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 2.75vw, 3rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--c-text);
    max-width: 36ch;
    margin: 0;
  }

  /* ── Bottom row: email + socials ─────────────────────── */
  .hero__scroll {
    background: none;
    border: none;
    /* Padded hit area (WCAG 2.5.8) without growing the visible glyph. */
    padding: 0.5rem 0.25rem;
    margin: -0.5rem -0.25rem;
    color: var(--c-text);
    cursor: pointer;
    font: inherit;
    transition: color 200ms;
  }

  /* The inner .overline span sets its own color via the .overline rule
     in typography.css, which beats inheritance from the parent button.
     Target the span directly so the hover swap actually shows. */
  .hero__scroll .hero__scroll-text {
    transition: color 200ms;
  }

  .hero__scroll:hover .hero__scroll-text,
  .hero__scroll:focus-visible .hero__scroll-text {
    color: var(--c-white);
  }

  .hero__scroll-arrow {
    display: inline-block;
    animation: scroll-bounce 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(0.25em); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-arrow { animation: none; }
  }

  .hero__socials {
    display: flex;
    gap: var(--sp-12);
    align-items: baseline;
  }

  .hero__socials a {
    transition: color 200ms;
    /* WCAG 2.5.8: ≥ 24 px hit target without changing visual size. */
    padding-block: 0.6rem;
    display: inline-block;
  }

  .hero__socials a:hover,
  .hero__socials a:focus-visible {
    color: var(--c-white);
  }

  .hero__socials-sep {
    color: var(--c-text-muted);
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero__inner {
      padding-top: 7.5rem;
      /* Same gutter-matched bottom on mobile. */
      padding-bottom: var(--gutter);
    }

    .hero__role-text {
      font-size: clamp(3rem, 16vw, 6rem);
    }

    .hero__desc {
      font-size: clamp(1.25rem, 4.5vw, 1.75rem);
    }
  }
</style>

<script>
  import { HeroKineticEffect } from '../scripts/HeroKineticEffect';
  import { fitByCanvas } from '../scripts/FitText';
  import { makePixelDrift } from '../scripts/PixelDrift';

  const scrollBtn = document.getElementById('hero-scroll');
  if (scrollBtn) {
    scrollBtn.addEventListener('click', () => {
      const target = document.getElementById('about');
      const lenis = (window as unknown as { __lenis?: { scrollTo: (t: HTMLElement | number) => void } }).__lenis;
      if (target && lenis) {
        lenis.scrollTo(target);
      } else {
        window.scrollTo({
          top: target ? target.getBoundingClientRect().top + window.scrollY : window.innerHeight,
          behavior: 'smooth',
        });
      }
    });
  }

  // Hero's kinetic variant: scroll stretches the dash and the "O".
  // Opts out of the generic auto-init via data-text-distortion-skip.
  const wrapper = document.querySelector<HTMLElement>('.hero__role');
  const canvas = document.getElementById('hero-role-canvas') as HTMLCanvasElement | null;
  const heroSection = document.querySelector<HTMLElement>('.hero');
  const isMobileLike = window.matchMedia(
    '(hover: none), (pointer: coarse), (max-width: 768px)'
  ).matches;
  if (wrapper && canvas && heroSection && !isMobileLike) {
    const effect = new HeroKineticEffect(wrapper, canvas, heroSection);
    effect.start();
  }

  // Fit the role text so the longest visible line spans the wrapper's full
  // width, BUT cap the font-size so 2 lines × fs × 0.85 (line-height) fits
  // in the height available inside .hero__center after .hero__desc is
  // accounted for. Otherwise the role overflows the viewport vertically on
  // shorter screens.
  const roleText = document.querySelector<HTMLElement>('.hero__role-text');
  const roleWrap = document.querySelector<HTMLElement>('.hero__role');
  const roleCenter = document.querySelector<HTMLElement>('.hero__center');
  const roleDesc = document.querySelector<HTMLElement>('.hero__desc');
  function fitHeroRole() {
    if (!roleText || !roleWrap) return;
    const containerW = roleWrap.getBoundingClientRect().width;

    // Width-fit: fontSize at which the longest line equals the wrapper width.
    const widthFs = fitByCanvas(
      ['RODRIGO LAGO', 'UX ENGINEER'],
      containerW,
      {
        weight: 400,
        family: '"Bebas Neue", Impact, sans-serif',
        letterSpacingEm: -0.02,
      },
    );
    if (widthFs <= 0) return;

    // Height-cap: largest fontSize that still lets 2 lines fit inside
    // .hero__center alongside .hero__desc and the column gap. centerH is
    // independent of role fontSize (.hero__center is flex: 1, sized by
    // the parent), so this is a stable upper bound per resize.
    let heightFs = Infinity;
    if (roleCenter && roleDesc) {
      const centerH = roleCenter.getBoundingClientRect().height;
      const descH = roleDesc.getBoundingClientRect().height;
      const cs = window.getComputedStyle(roleCenter);
      const gap = parseFloat(cs.rowGap || cs.gap || '0') || 0;
      const availableForRole = centerH - descH - gap;
      if (availableForRole > 0) {
        // 2 lines × line-height 0.85 = role-text height per fontSize unit
        heightFs = availableForRole / (2 * 0.85);
      }
    }

    roleText.style.fontSize = `${Math.min(widthFs, heightFs)}px`;
  }
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(fitHeroRole);
  } else {
    fitHeroRole();
  }
  window.addEventListener('resize', fitHeroRole, { passive: true });

  // Pixelated background canvas — shared makePixelDrift factory (same as
  // FAQ row glow). Renders a tiny canvas that CSS stretches with
  // image-rendering: pixelated so each internal pixel becomes a chunky
  // block; the source offset drifts via a spring chase.
  const heroBgCanvas = document.getElementById('hero-bg-canvas') as HTMLCanvasElement | null;
  const heroBg = heroBgCanvas?.parentElement as HTMLElement | null;
  if (heroBgCanvas && heroBg) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const bgImg = new Image();
    bgImg.decoding = 'async';
    bgImg.src = '/images/background.png';
    bgImg.onload = () => {
      const drift = makePixelDrift(heroBgCanvas, heroBg, bgImg);
      if (reduced) {
        drift.renderOnce();
      } else {
        drift.start();
        window.addEventListener('resize', drift.resize, { passive: true });
      }
    };
  }
</script>
