---
import StarIcon from './StarIcon.astro';

interface Props {
  index: string;
  rightLabel?: string;
  /** Kept for API stability; both values render the marquee star SVG now. */
  rightIcon?: 'asterisk' | 'star' | 'none';
}
const { index, rightLabel, rightIcon = 'asterisk' } = Astro.props;
const showIcon = rightIcon !== 'none';
---

<div class="section-meta" data-reveal>
  <span class="section-meta__item overline">
    <span class="section-meta__dot" aria-hidden="true"></span>
    Section &middot; {index}
  </span>
  {rightLabel && (
    <span class="section-meta__item overline">
      {showIcon && <StarIcon class="section-meta__star" />}
      {rightLabel}
    </span>
  )}
</div>
<div class="line line--draw" data-line-draw></div>

<style>
  .section-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    color: var(--c-text-muted);
    /* Breathing room above the meta line that sits right beneath it. */
    padding-bottom: var(--sp-6);
  }

  /* The hairline that follows the meta strip — push it a touch further
     down so the eye reads meta-text and line as two beats, not one. */
  .section-meta + .line {
    margin-top: var(--sp-12);
  }

  .section-meta__item {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
  }

  .section-meta__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-text);
    display: inline-block;
    /* Slow tonal fade between ink and muted-ink — reads as a soft
       titillation; never goes dim enough to disappear. No size change. */
    animation: section-meta-dot-tint 3.2s ease-in-out infinite;
    will-change: background-color;
  }

  @keyframes section-meta-dot-tint {
    0%, 100% { opacity: 1; }
    60%      { opacity: 0.2; }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-meta__dot {
      animation: none;
      background: var(--c-text);
    }
  }

  /* Marquee-matching star. Rotation is driven by page scroll via JS
     setting --star-rotate on the element. :global() because the SVG is
     rendered by <StarIcon/> — its own scope doesn't see SectionMeta's
     astro-cid, so the rule has to be unscoped. */
  /* Fixed glyph size — not 1em (would scale with parent font-size) and
     not a vw clamp (would balloon on wide viewports, beating the eyebrow
     copy beside it). svg.{class} bumps specificity so the global
     `.svg-star` default doesn't win on cascade order. */
  :global(svg.section-meta__star) {
    width: 0.95rem;
    height: auto;
    color: var(--c-text);
    display: inline-block;
    vertical-align: middle;
    transform-origin: 50% 50%;
    transform: rotate(var(--star-rotate, 0deg));
    will-change: transform;
    transition: transform 60ms linear;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(svg.section-meta__star) {
      transition: none;
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .section-meta {
      gap: var(--sp-12);
    }
  }
</style>

<script>
  // Scroll-driven star spin. One RAF per scroll event, shared across all
  // section-meta stars on the page. Mapping: 0 → max scroll = 0 → 720°.
  // The scroll-timeline CSS path was dropped because it had no visible
  // effect under Lenis smooth scroll; the JS path is bulletproof.
  const reduced =
    typeof window !== 'undefined' &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    const stars = Array.from(
      document.querySelectorAll<HTMLElement>('.section-meta__star'),
    );
    if (stars.length > 0) {
      const ROTATIONS = 720; // total degrees over the full page scroll
      let raf = 0;
      const update = () => {
        raf = 0;
        const doc = document.documentElement;
        const max = doc.scrollHeight - window.innerHeight;
        const ratio = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
        const deg = ratio * ROTATIONS;
        stars.forEach((s) => s.style.setProperty('--star-rotate', `${deg}deg`));
      };
      const onScroll = () => {
        if (raf) return;
        raf = requestAnimationFrame(update);
      };
      update();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      // Lenis emits native scroll events, but on first paint scrollY may
      // be 0 before fonts/images settle the layout. Re-run after load.
      window.addEventListener('load', update);
    }
  }
</script>
