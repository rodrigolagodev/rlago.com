<!-- Polygons in each half are absolutely positioned so the logo's centre
     sits at the half boundary (= viewport centre). The half's overflow
     clips off the other half's portion; on exit each half slides off
     carrying its own half of the logo. -->
<div class="loader" id="page-loader" aria-hidden="true">

  <div class="loader__half is-top" id="loader-half-top">
    <svg class="loader__logo" viewBox="0 0 359.9 344.7" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g>
        <polygon points="320.9,0 359.9,67.5 279.9,206.2 202.7,206.2"/>
        <polygon points="320.8,275.4 281.3,341.9 202.7,206.2 241.6,138.6"/>
        <polygon points="359.9,67.5 320.9,0 84.5,0 45.5,67.5"/>
        <polygon points="39,344.7 0,277.2 80,138.6 157.2,138.6"/>
        <polygon points="0,277.2 39,344.7 198.9,344.7 161.3,277.2"/>
      </g>
    </svg>
  </div>

  <div class="loader__half is-bottom" id="loader-half-bottom">
    <svg class="loader__logo" viewBox="0 0 359.9 344.7" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g>
        <polygon points="320.9,0 359.9,67.5 279.9,206.2 202.7,206.2"/>
        <polygon points="320.8,275.4 281.3,341.9 202.7,206.2 241.6,138.6"/>
        <polygon points="359.9,67.5 320.9,0 84.5,0 45.5,67.5"/>
        <polygon points="39,344.7 0,277.2 80,138.6 157.2,138.6"/>
        <polygon points="0,277.2 39,344.7 198.9,344.7 161.3,277.2"/>
      </g>
    </svg>
  </div>

</div>

<style>
  .loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: all;
    overflow: hidden;
  }

  .loader__half {
    position: absolute;
    left: 0;
    right: 0;
    height: 50%;
    background-color: var(--c-bg);
    overflow: hidden;
    transition: transform 700ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  .loader__half.is-top    { top: 0; }
  .loader__half.is-bottom { bottom: 0; }

  .loader__half.is-top.is-exit    { transform: translateY(-100%); }
  .loader__half.is-bottom.is-exit { transform: translateY(100%); }

  .loader__logo {
    position: absolute;
    left: 50%;
    width: clamp(7rem, 16vw, 12rem);
    height: auto;
    aspect-ratio: 359.9 / 344.7;
  }

  .loader__half.is-top .loader__logo {
    bottom: 0;
    transform: translate(-50%, 50%);
  }

  .loader__half.is-bottom .loader__logo {
    top: 0;
    transform: translate(-50%, -50%);
  }

  /* 5 polygons, 100ms stagger — wave of brightness across the logo. */
  .loader__logo polygon {
    fill: var(--c-logo);
    opacity: 0.25;
    animation: loader-pulse 1.4s ease-in-out infinite;
  }

  .loader__logo polygon:nth-child(1) { animation-delay: 0ms; }
  .loader__logo polygon:nth-child(2) { animation-delay: 100ms; }
  .loader__logo polygon:nth-child(3) { animation-delay: 200ms; }
  .loader__logo polygon:nth-child(4) { animation-delay: 300ms; }
  .loader__logo polygon:nth-child(5) { animation-delay: 400ms; }

  @keyframes loader-pulse {
    0%, 100% { opacity: 0.25; }
    50%      { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .loader__logo polygon {
      animation: none;
      opacity: 1;
    }
    .loader__half {
      transition: none;
    }
  }

  .loader.is-done {
    pointer-events: none;
  }
</style>

<script>
  (function () {
    const loader     = document.getElementById('page-loader')!;
    const halfTop    = document.getElementById('loader-half-top')!;
    const halfBottom = document.getElementById('loader-half-bottom')!;

    document.body.style.overflow = 'hidden';

    // Reduced motion: skip the choreography, unblock the page immediately.
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const LOADING_DURATION = reduced ? 0 : 1800;
    const SLIDE_DURATION = reduced ? 0 : 750;

    setTimeout(exitLoader, LOADING_DURATION);

    function exitLoader() {
      halfTop.classList.add('is-exit');
      halfBottom.classList.add('is-exit');

      setTimeout(() => {
        loader.classList.add('is-done');
        loader.style.display = 'none';
        document.body.style.overflow = '';

        document.body.classList.add('hero-ready');
        document.dispatchEvent(new CustomEvent('loader:done'));
      }, SLIDE_DURATION);
    }
  })();
</script>
